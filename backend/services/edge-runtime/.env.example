# Copy to .env and adjust. Everything has a local-first default, so the closed
# loop runs with ZERO of these set.

# ── Database ────────────────────────────────────────────────────────────────
# Local default is SQLite. For Cloud SQL Postgres use one of:
#   postgresql+psycopg://USER:PASS@/DBNAME?host=/cloudsql/PROJECT:REGION:INSTANCE   (Cloud Run socket)
#   postgresql+psycopg://USER:PASS@HOST:5432/DBNAME                                  (TCP / proxy)
DATABASE_URL=sqlite:///./dev.db

# ── Inference provider ──────────────────────────────────────────────────────
# mock | vertex | local | jetson
INFER_PROVIDER=mock

# ── Storage ─────────────────────────────────────────────────────────────────
# local | gcs
STORAGE_BACKEND=local
STORAGE_DIR=./storage
GCS_BUCKET=

# ── Vertex AI (INFER_PROVIDER=vertex) ───────────────────────────────────────
GCP_PROJECT=
GCP_LOCATION=us-central1
VERTEX_MODEL=gemini-2.0-flash

# ── Local LLM (INFER_PROVIDER=local, e.g. Ollama serving a VLM) ──────────────
LOCAL_LLM_URL=http://localhost:11434
LOCAL_LLM_MODEL=qwen2-vl

# ── Jetson edge service (INFER_PROVIDER=jetson) ─────────────────────────────
JETSON_URL=

# ── Business rules ──────────────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.85

# CORS — the Vite dev server
FRONTEND_ORIGIN=http://localhost:5173
